# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client. Used only by
# app/api/onboarding/create-company (company creation happens before the
# new user has a company_id, so RLS can't apply yet).
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key, used by app/api/onboarding/parse-quotes and
# app/api/quotes/suggest for AI-assisted parsing and quote drafting.
ANTHROPIC_API_KEY=
